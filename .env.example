# === Discord bot (server/) ===
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# === Supabase ===
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# === Market data ===
FINNHUB_API_KEY=

# === CRM API (server) ===
# Optional: set CRM_ADMIN_API_KEY to require X-Admin-Key on /api/* routes
CRM_API_PORT=8000
PORT=8000
CRM_CORS_ORIGINS=http://localhost:5173
# Set true to allow any browser origin (dev only)
CRM_CORS_ALLOW_ALL=false
# Serve built CRM from Railway at /
SERVE_CRM=false

# === CRM frontend (crm/) — Vercel env ===
VITE_API_URL=https://your-app.up.railway.app

# Subscribe / billing channels (optional overrides)
# SUBSCRIBE_CHANNEL=subscribe
# SUBSCRIBE_CHANNEL_CANDIDATES=subscribe,player,registration,register,𝐏𝐋𝐀𝐘𝐄𝐑
# MANAGE_SUBSCRIPTION_CHANNEL=manage-subscription

# === Stripe (optional) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_SUCCESS_URL=https://discord.com/channels/@me
STRIPE_CANCEL_URL=https://discord.com/channels/@me
STRIPE_PORTAL_RETURN_URL=https://discord.com/channels/@me
# Local dev only: separate aiohttp listener. On Railway leave unset (uses POST /stripe/webhook on PORT).
# STRIPE_WEBHOOK_PORT=8081

# === Transactional email (optional) ===
# Subscription lifecycle emails (created / renewed / canceled / failed).
# If neither provider is set, the bot logs the intended email and keeps working.
# Option A — Resend (recommended):
# RESEND_API_KEY=
# EMAIL_FROM=Meme Stock Game <noreply@yourdomain.com>
# Option B — SMTP:
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
